# Claude Kakao Notify — NAS notify-api 접속 설정
# install.ps1 실행 시 자동 생성됨. 수동 편집 가능.

# NAS host (DDNS 도메인, 외부 IP, 또는 LAN IP)
NOTIFY_API_HOST=your-nas-host-or-ip

# 외부 포트 (포트포워딩 외부 포트)
NOTIFY_API_PORT=8002

# notify-api 컨테이너 발급 API 키
NOTIFY_API_KEY=your-api-key

# (선택) HTTPS 사용 시 https로 변경 — 기본 http
# NOTIFY_API_SCHEME=http

# (선택) 엔드포인트 경로 — 기본 /notify
# NOTIFY_API_PATH=/notify

# (선택) HOST/PORT 대신 전체 URL을 직접 지정하고 싶을 때
# NOTIFY_API_URL=http://your-nas-host:8002/notify
